# Smart Collection Environment Variables Example
# Duplicate this file as .env and fill in your values. Do not commit .env to version control.

# MongoDB Connection String (e.g. from MongoDB Atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/smart_collection?retryWrites=true&w=majority

# Port for the application backend to run on
PORT=3000

# Merchant Details for UPI QR Code Payments
MERCHANT_NAME="Sushant Singh"
UPI_ID="sshushant074@oksbi"

# Google Sign-In Client ID (Get this from Google Cloud Console credentials)
GOOGLE_CLIENT_ID=your-google-oauth-client-id-here.apps.googleusercontent.com

# Razorpay API Credentials
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret



